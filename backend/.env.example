# ──────── BizEngine Environment Configuration ────────

# AI Analysis Providers (at least one required for AI Insights)
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here


# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=generate_a_random_string_for_production

# Database Configuration (Defaults to local SQLite if not provided)
# For production (Render/Heroku/Railway), use your PostgreSQL URL
DATABASE_URL=sqlite:///bizengine.db

# Frontend Configuration (for production build)
# VITE_API_URL=https://your-backend-api.onrender.com
